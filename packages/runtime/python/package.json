{
  "name": "@secure-exec/runtime-python",
  "version": "0.1.1-rc.3",
  "description": "Python runtime driver — wraps Pyodide behind the kernel RuntimeDriver interface",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
