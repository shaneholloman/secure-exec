{
  "name": "@nano-sandbox/fs-polyfill",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fs-module.js": {
      "import": "./dist/fs-module.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "buffer": "^6.0.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
