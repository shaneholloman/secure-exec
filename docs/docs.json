{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "dark": "#09090b"
    }
  },
  "name": "Secure Exec",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg"
  },
  "colors": {
    "primary": "#CC0000",
    "light": "#FF3333",
    "dark": "#CC0000"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["quickstart", "sdk-overview"]
      },
      {
        "group": "Runtimes",
        "pages": [
          "runtimes/overview",
          "runtimes/node",
          "runtimes/python"
        ]
      },
      {
        "group": "System Drivers",
        "pages": [
          "system-drivers/overview",
          "system-drivers/node",
          "system-drivers/browser"
        ]
      },
      {
        "group": "Kernel",
        "pages": [
          "kernel/quickstart",
          "kernel/api-reference",
          "kernel/cross-runtime",
          "kernel/custom-runtime"
        ]
      },
      {
        "group": "Features",
        "pages": [
          "features/permissions",
          "features/filesystem",
          "features/networking",
          "features/module-loading",
          "features/resource-limits",
          "features/typescript",
          "features/child-processes",
          "features/output-capture"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "api-reference",
          "architecture",
          "security-model",
          "nodejs-compatibility",
          "python-compatibility",
          "cloudflare-workers-comparison"
        ]
      }
    ]
  }
}
